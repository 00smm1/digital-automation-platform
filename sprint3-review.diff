+
+  it('executes handlers in deterministic subscription order', async () => {
+    const bus = new InMemoryEventBus();
+    const order: string[] = [];
+
+    bus.subscribe(
+      TestEventName,
+      createHandler(TestEventName, async () => {
+        order.push('first');
+      }),
+    );
+    bus.subscribe(
+      TestEventName,
+      createHandler(TestEventName, async () => {
+        order.push('second');
